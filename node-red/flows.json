    {
        "id": "9da3a8967bafe7b1",
        "type": "function",
        "z": "76fadeb220138296",
        "name": "Motor Health",
        "func": "let data = JSON.parse(msg.payload);\n\nlet score = 100;\n\n// Temperatur\nscore -= (data.temperature / 100) * 30;\n\n// Getaran\nscore -= (data.vibration / 4095) * 40;\n\n// Arus\nscore -= (data.current / 10) * 30;\n\nscore = Math.max(0, Math.round(score));\n\nmsg.payload = score;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
