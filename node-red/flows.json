    {
        "id": "dc06eea75742bf56",
        "type": "function",
        "z": "76fadeb220138296",
        "name": "Failure Risk",
        "func": "let fault = flow.get(\"countFault\") || 0;\nlet warning = flow.get(\"countWarning\") || 0;\nlet prediction = flow.get(\"lastPrediction\") || \"NORMAL\";\n\nlet risk = 0;\n\nif (prediction === \"NORMAL\") risk += 20;\nelse if (prediction === \"WARNING\") risk += 50;\nelse risk += 80;\n\nrisk += warning * 2;\nrisk += fault * 5;\n\nif (risk > 100) risk = 100;\n\nlet level = \"\";\n\nif (risk < 40)\n    level = \"LOW\";\nelse if (risk < 70)\n    level = \"MEDIUM\";\nelse\n    level = \"HIGH\";\n\nmsg.payload = risk + \"% (\" + level + \")\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
