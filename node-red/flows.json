        "type": "function",
        "z": "76fadeb220138296",
        "name": "Save Dataset",
        "func": "let d = JSON.parse(msg.payload);\n\nlet status = \"NORMAL\";\n\nif (d.temperature > 50 || d.vibration > 3000) {\n    status = \"FAULT\";\n}\nelse if (d.temperature > 40 || d.vibration > 1500) {\n    status = \"WARNING\";\n}\n\nmsg.payload =\n`${d.temperature},${d.humidity},${d.vibration},${d.current},${status}\\n`;\n\nreturn msg;",
        "outputs": 1,
