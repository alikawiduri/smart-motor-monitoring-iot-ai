    {
        "id": "78f8966a17417a38",
        "type": "function",
        "z": "76fadeb220138296",
        "name": "Count Function",
        "func": "let countFault = flow.get('countFault') || 0;\nlet countWarning = flow.get('countWarning') || 0;\n\nif (msg.payload === \"FAULT\") {\n    countFault++;\n}\nelse if (msg.payload === \"WARNING\") {\n    countWarning++;\n}\n\nflow.set('countFault', countFault);\nflow.set('countWarning', countWarning);\n\nmsg.payload =\n    \"Fault Count : \" + countFault +\n    \"<br>Warning Count : \" + countWarning;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 840,
        "wires": [
