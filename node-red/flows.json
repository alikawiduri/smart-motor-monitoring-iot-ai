    {
        "id": "d19adb35f0a0e921",
        "type": "function",
        "z": "76fadeb220138296",
        "name": "Status",
        "func": "if (typeof msg.payload === \"string\") {\n    msg.payload = JSON.parse(msg.payload);\n}\n\nvar temp = parseFloat(msg.payload.temperature);\nvar vib = parseFloat(msg.payload.vibration);\n\nif (temp >= 50 || vib >= 3000) {\n    msg.payload = \"FAULT\";\n}\nelse if (temp >= 40 || vib >= 1500) {\n    msg.payload = \"WARNING\";\n}\nelse {\n    msg.payload = \"NORMAL\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 760,
